{
    "paths": {
        "input_dir": "E:/FotosMama",
        "output_importantes": "E:/FotosProcesadas/importantes",
        "output_no_importantes": "E:/FotosProcesadas/no_importantes"
    },
    "processing": {
        "num_workers": 2,
        "batch_size_clip": 10,
        "device": "cuda",
        "video_sample_frames": 3,
        "time_window_minutes": 1
    },
    "memory_management": {
        "max_ram_mb": 2048,
        "adaptive_blocks": true,
        "min_block_size": 10,
        "max_block_size": 500,
        "estimate_bytes_per_file": 5242880
    },
    "thresholds": {
        "min_blur_variance": 20.0,
        "max_darkness_ratio": 0.85,
        "similarity_threshold": 0.90,
        "min_score_important": 2.0
    },
    "scoring_weights": {
        "has_faces": 5.0,
        "has_a_person": 5.0,
        "is_blurry": -2.0,
        "is_dark": -2.0,
        "is_screenshot": -10.0,
        "is_document": -5.0,
        "is_family_moment": 10.0,
        "is_landscape": 5.0,
        "is_pet": 5.0,
        "is_selfie": 5.0,
        "is_food": -1.0
    }
}
